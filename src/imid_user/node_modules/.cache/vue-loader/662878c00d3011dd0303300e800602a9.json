{"remainingRequest":"D:\\IMID\\src\\imid_user\\node_modules\\vue-loader\\lib\\index.js??vue-loader-options!D:\\IMID\\src\\imid_user\\views\\admin\\Dashboard.vue?vue&type=script&lang=js","dependencies":[{"path":"D:\\IMID\\src\\imid_user\\views\\admin\\Dashboard.vue","mtime":1740842287968},{"path":"D:\\IMID\\src\\imid_user\\node_modules\\cache-loader\\dist\\cjs.js","mtime":1742797319747},{"path":"D:\\IMID\\src\\imid_user\\node_modules\\thread-loader\\dist\\cjs.js","mtime":1742797319731},{"path":"D:\\IMID\\src\\imid_user\\node_modules\\babel-loader\\lib\\index.js","mtime":1742797321231},{"path":"D:\\IMID\\src\\imid_user\\node_modules\\cache-loader\\dist\\cjs.js","mtime":1742797319747},{"path":"D:\\IMID\\src\\imid_user\\node_modules\\vue-loader\\lib\\index.js","mtime":1742797321828}],"contextDependencies":[],"result":[{"type":"Buffer","data":"base64:"},{"version":3,"sources":["Dashboard.vue"],"names":[],"mappings":";AAyHA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA","file":"Dashboard.vue","sourceRoot":"views/admin","sourcesContent":["<template>\r\n  <div class=\"dashboard\">\r\n    <!-- 系统状态概览 -->\r\n    <el-row :gutter=\"20\" class=\"status-overview\">\r\n      <el-col :span=\"6\">\r\n        <el-card shadow=\"hover\">\r\n          <div class=\"status-item\">\r\n            <div class=\"icon\">\r\n              <i class=\"el-icon-cpu\"></i>\r\n            </div>\r\n            <div class=\"info\">\r\n              <div class=\"title\">CPU使用率</div>\r\n              <div class=\"value\">{{ cpuUsage }}%</div>\r\n            </div>\r\n          </div>\r\n        </el-card>\r\n      </el-col>\r\n      <el-col :span=\"6\">\r\n        <el-card shadow=\"hover\">\r\n          <div class=\"status-item\">\r\n            <div class=\"icon\">\r\n              <i class=\"el-icon-coin\"></i>\r\n            </div>\r\n            <div class=\"info\">\r\n              <div class=\"title\">内存使用率</div>\r\n              <div class=\"value\">{{ memoryUsage }}%</div>\r\n            </div>\r\n          </div>\r\n        </el-card>\r\n      </el-col>\r\n      <el-col :span=\"6\">\r\n        <el-card shadow=\"hover\">\r\n          <div class=\"status-item\">\r\n            <div class=\"icon\">\r\n              <i class=\"el-icon-folder\"></i>\r\n            </div>\r\n            <div class=\"info\">\r\n              <div class=\"title\">存储使用率</div>\r\n              <div class=\"value\">{{ storageUsage }}%</div>\r\n            </div>\r\n          </div>\r\n        </el-card>\r\n      </el-col>\r\n      <el-col :span=\"6\">\r\n        <el-card shadow=\"hover\">\r\n          <div class=\"status-item\">\r\n            <div class=\"icon\">\r\n              <i class=\"el-icon-connection\"></i>\r\n            </div>\r\n            <div class=\"info\">\r\n              <div class=\"title\">在线用户</div>\r\n              <div class=\"value\">{{ onlineUsers }}</div>\r\n            </div>\r\n          </div>\r\n        </el-card>\r\n      </el-col>\r\n    </el-row>\r\n\r\n    <!-- 监控图表 -->\r\n    <el-row :gutter=\"20\" class=\"monitor-charts\">\r\n      <el-col :span=\"12\">\r\n        <el-card class=\"chart-card\">\r\n          <div slot=\"header\">\r\n            <span>系统资源使用趋势</span>\r\n          </div>\r\n          <div class=\"chart\" ref=\"resourceChart\"></div>\r\n        </el-card>\r\n      </el-col>\r\n      <el-col :span=\"12\">\r\n        <el-card class=\"chart-card\">\r\n          <div slot=\"header\">\r\n            <span>系统日志</span>\r\n            <el-button style=\"float: right; padding: 3px 0\" type=\"text\" @click=\"viewAllLogs\">\r\n              查看全部\r\n            </el-button>\r\n          </div>\r\n          <el-table :data=\"logs\" style=\"width: 100%\" height=\"300\">\r\n            <el-table-column prop=\"timestamp\" label=\"时间\" width=\"180\">\r\n              <template slot-scope=\"scope\">\r\n                {{ formatDate(scope.row.timestamp) }}\r\n              </template>\r\n            </el-table-column>\r\n            <el-table-column prop=\"level\" label=\"级别\" width=\"100\">\r\n              <template slot-scope=\"scope\">\r\n                <el-tag :type=\"getLogLevelType(scope.row.level)\">\r\n                  {{ scope.row.level }}\r\n                </el-tag>\r\n              </template>\r\n            </el-table-column>\r\n            <el-table-column prop=\"message\" label=\"内容\"></el-table-column>\r\n          </el-table>\r\n        </el-card>\r\n      </el-col>\r\n    </el-row>\r\n\r\n    <!-- 告警面板 -->\r\n    <el-dialog\r\n      title=\"系统告警\"\r\n      :visible.sync=\"showAlertDialog\"\r\n      width=\"500px\"\r\n    >\r\n      <div class=\"alert-content\">\r\n        <i class=\"el-icon-warning\"></i>\r\n        <div class=\"alert-message\">\r\n          <h3>{{ currentAlert.title }}</h3>\r\n          <p>{{ currentAlert.message }}</p>\r\n        </div>\r\n      </div>\r\n      <div class=\"alert-suggestion\">\r\n        <h4>处理建议：</h4>\r\n        <p>{{ currentAlert.suggestion }}</p>\r\n      </div>\r\n      <span slot=\"footer\" class=\"dialog-footer\">\r\n        <el-button @click=\"showAlertDialog = false\">关闭</el-button>\r\n        <el-button type=\"primary\" @click=\"handleAlert\">处理</el-button>\r\n      </span>\r\n    </el-dialog>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nimport * as echarts from 'echarts'\r\nimport { formatDate } from '@/utils/format'\r\nimport { getSystemLogs, getSystemMetrics, getSystemStatistics } from '@/api/admin'\r\n\r\nexport default {\r\n  name: 'AdminDashboard',\r\n  data() {\r\n    return {\r\n      cpuUsage: 45,\r\n      memoryUsage: 60,\r\n      storageUsage: 75,\r\n      onlineUsers: 128,\r\n      logs: [],\r\n      showAlertDialog: false,\r\n      currentAlert: {\r\n        title: '',\r\n        message: '',\r\n        suggestion: ''\r\n      },\r\n      resourceChart: null\r\n    }\r\n  },\r\n  mounted() {\r\n    this.initResourceChart()\r\n    this.startMonitoring()\r\n    this.fetchSystemLogs()\r\n  },\r\n  beforeDestroy() {\r\n    if (this.resourceChart) {\r\n      this.resourceChart.dispose()\r\n    }\r\n  },\r\n  methods: {\r\n    formatDate,\r\n    initResourceChart() {\r\n      this.resourceChart = echarts.init(this.$refs.resourceChart)\r\n      const option = {\r\n        tooltip: {\r\n          trigger: 'axis'\r\n        },\r\n        legend: {\r\n          data: ['CPU', '内存', '存储']\r\n        },\r\n        xAxis: {\r\n          type: 'time',\r\n          boundaryGap: false\r\n        },\r\n        yAxis: {\r\n          type: 'value',\r\n          max: 100,\r\n          min: 0\r\n        },\r\n        series: [\r\n          {\r\n            name: 'CPU',\r\n            type: 'line',\r\n            data: this.generateMockData()\r\n          },\r\n          {\r\n            name: '内存',\r\n            type: 'line',\r\n            data: this.generateMockData()\r\n          },\r\n          {\r\n            name: '存储',\r\n            type: 'line',\r\n            data: this.generateMockData()\r\n          }\r\n        ]\r\n      }\r\n      this.resourceChart.setOption(option)\r\n    },\r\n    generateMockData() {\r\n      const now = new Date()\r\n      const data = []\r\n      for (let i = 0; i < 72; i++) {\r\n        data.unshift([\r\n          new Date(now - i * 3600 * 1000),\r\n          Math.round(Math.random() * 30 + 40)\r\n        ])\r\n      }\r\n      return data\r\n    },\r\n    startMonitoring() {\r\n      // TODO: 实现实时监控逻辑\r\n    },\r\n    async fetchSystemLogs() {\r\n      try {\r\n        const response = await getSystemLogs({ limit: 10 }) // 获取最近10条日志\r\n        if (response && response.data) {\r\n          // 处理后端返回的嵌套数据结构\r\n          if (response.data.data && response.data.data.content) {\r\n            this.logs = response.data.data.content.map(log => ({\r\n              timestamp: new Date(log.timestamp),\r\n              level: log.level,\r\n              message: log.message\r\n            }));\r\n          }\r\n          // 处理分页格式的返回数据\r\n          else if (response.data.content && Array.isArray(response.data.content)) {\r\n            this.logs = response.data.content.map(log => ({\r\n              timestamp: new Date(log.timestamp),\r\n              level: log.level,\r\n              message: log.message\r\n            }));\r\n          }\r\n          // 处理直接返回数组的情况\r\n          else if (Array.isArray(response.data)) {\r\n            this.logs = response.data.map(log => ({\r\n              timestamp: new Date(log.timestamp),\r\n              level: log.level,\r\n              message: log.message\r\n            }));\r\n          }\r\n          // 如果没有数据，使用示例数据\r\n          else {\r\n            console.warn('系统日志数据格式不符合预期', response.data);\r\n            this.setMockLogs();\r\n          }\r\n        } else {\r\n          this.setMockLogs();\r\n        }\r\n      } catch (error) {\r\n        console.error('获取系统日志失败:', error);\r\n        this.setMockLogs();\r\n      }\r\n    },\r\n    \r\n    // 设置示例日志数据\r\n    setMockLogs() {\r\n      this.logs = [\r\n        {\r\n          timestamp: new Date(),\r\n          level: 'ERROR',\r\n          message: '数据库连接失败'\r\n        },\r\n        {\r\n          timestamp: new Date(Date.now() - 3600 * 1000),\r\n          level: 'INFO',\r\n          message: '系统启动成功'\r\n        }\r\n      ];\r\n    },\r\n    getLogLevelType(level) {\r\n      const types = {\r\n        ERROR: 'danger',\r\n        WARNING: 'warning',\r\n        INFO: 'info',\r\n        DEBUG: 'success'\r\n      }\r\n      return types[level] || 'info'\r\n    },\r\n    handleAlert() {\r\n      // TODO: 实现告警处理逻辑\r\n      this.showAlertDialog = false\r\n    },\r\n    viewAllLogs() {\r\n      this.$router.push('/admin/system-logs')\r\n    }\r\n  }\r\n}\r\n</script>\r\n\r\n<style lang=\"scss\" scoped>\r\n.dashboard {\r\n  .status-overview {\r\n    margin-bottom: 20px;\r\n\r\n    .status-item {\r\n      display: flex;\r\n      align-items: center;\r\n      \r\n      .icon {\r\n        font-size: 48px;\r\n        margin-right: 20px;\r\n        color: #409EFF;\r\n      }\r\n\r\n      .info {\r\n        .title {\r\n          font-size: 14px;\r\n          color: #909399;\r\n        }\r\n\r\n        .value {\r\n          font-size: 24px;\r\n          font-weight: bold;\r\n          color: #303133;\r\n        }\r\n      }\r\n    }\r\n  }\r\n\r\n  .monitor-charts {\r\n    .chart-card {\r\n      margin-bottom: 20px;\r\n\r\n      .chart {\r\n        height: 300px;\r\n      }\r\n    }\r\n  }\r\n\r\n  .alert-content {\r\n    display: flex;\r\n    align-items: flex-start;\r\n    margin-bottom: 20px;\r\n\r\n    .el-icon-warning {\r\n      font-size: 24px;\r\n      color: #E6A23C;\r\n      margin-right: 15px;\r\n    }\r\n\r\n    .alert-message {\r\n      h3 {\r\n        margin: 0 0 10px;\r\n        color: #303133;\r\n      }\r\n\r\n      p {\r\n        margin: 0;\r\n        color: #606266;\r\n      }\r\n    }\r\n  }\r\n\r\n  .alert-suggestion {\r\n    background: #F5F7FA;\r\n    padding: 15px;\r\n    border-radius: 4px;\r\n\r\n    h4 {\r\n      margin: 0 0 10px;\r\n      color: #303133;\r\n    }\r\n\r\n    p {\r\n      margin: 0;\r\n      color: #606266;\r\n    }\r\n  }\r\n}\r\n</style> "]}]}