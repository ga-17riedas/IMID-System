        <div class=\"avatar\">\n          <el-avatar :size=\"80\" icon=\"el-icon-user-solid\"></el-avatar>\n        </div>\n        <div class=\"welcome-text\">\n          <h2>欢迎回来, {{ doctorInfo.fullName }}</h2>\n          <p>{{ doctorInfo.hospital }} | {{ doctorInfo.department }} | {{ doctorInfo.professionalTitle }}</p>\n        </div>\n      </div>\n    </el-card>\n\n    <!-- 统计数据卡片 -->\n    <el-row :gutter=\"24\" class=\"stat-row\">\n      <el-col :span=\"8\">\n        <el-card class=\"stat-card\" shadow=\"hover\">\n          <div class=\"stat-icon\">\n            <i class=\"el-icon-picture-outline\"></i>\n          </div>\n          <div class=\"stat-info\">\n            <div class=\"stat-value\">{{ stats.pendingImages || 0 }}</div>\n            <div class=\"stat-label\">待分析影像</div>\n          </div>\n          <el-button type=\"text\" class=\"stat-action\" @click=\"$router.push('/doctor/image-analysis')\">\n            前往分析 <i class=\"el-icon-arrow-right\"></i>\n          </el-button>\n        </el-card>\n      </el-col>\n\n      <el-col :span=\"8\">\n        <el-card class=\"stat-card\" shadow=\"hover\">\n          <div class=\"stat-icon\">\n            <i class=\"el-icon-user\"></i>\n          </div>\n          <div class=\"stat-info\">\n            <div class=\"stat-value\">{{ stats.todayPatients || 0 }}</div>\n            <div class=\"stat-label\">今日患者</div>\n          </div>\n          <el-button type=\"text\" class=\"stat-action\" @click=\"$router.push('/doctor/patients')\">\n            查看患者 <i class=\"el-icon-arrow-right\"></i>\n          </el-button>\n        </el-card>\n      </el-col>\n\n      <el-col :span=\"8\">\n        <el-card class=\"stat-card\" shadow=\"hover\">\n          <div class=\"stat-icon\">\n            <i class=\"el-icon-document\"></i>\n          </div>\n          <div class=\"stat-info\">\n            <div class=\"stat-value\">{{ stats.totalReports || 0 }}</div>\n            <div class=\"stat-label\">诊断报告</div>\n          </div>\n          <el-button type=\"text\" class=\"stat-action\" @click=\"$router.push('/doctor/reports')\">\n            查看报告 <i class=\"el-icon-arrow-right\"></i>\n          </el-button>\n        </el-card>\n      </el-col>\n    </el-row>\n\n    <!-- 系统信息卡片 -->\n    <el-row :gutter=\"24\" class=\"info-row\">\n      <el-col :span=\"12\">\n        <el-card class=\"info-card\" shadow=\"hover\">\n          <div slot=\"header\" class=\"info-header\">\n            <span>系统介绍</span>\n          </div>\n          <div class=\"info-content\">\n            <p class=\"info-title\">IMID 医学影像诊断系统</p>\n            <p class=\"info-desc\">\n              基于深度学习和大语言模型的智能医疗影像诊断辅助系统(IMID)是一款专为医疗影像诊断领域设计的智能辅助平台。\n              系统采用YOLOv8深度学习模型算法，旨在提升医疗影像诊断的准确性和效率。\n            </p>\n            <div class=\"feature-list\">\n              <div class=\"feature-item\">\n                <i class=\"el-icon-check\"></i>\n                <span>智能影像分析</span>\n              </div>\n              <div class=\"feature-item\">\n                <i class=\"el-icon-check\"></i>\n                <span>辅助诊断建议</span>\n              </div>\n              <div class=\"feature-item\">\n                <i class=\"el-icon-check\"></i>\n                <span>患者数据管理</span>\n              </div>\n              <div class=\"feature-item\">\n                <i class=\"el-icon-check\"></i>\n                <span>报告自动生成</span>\n              </div>\n            </div>\n          </div>\n        </el-card>\n      </el-col>\n\n      <el-col :span=\"12\">\n        <el-card class=\"info-card\" shadow=\"hover\">\n          <div slot=\"header\" class=\"info-header\">\n            <span>快捷操作</span>\n          </div>\n          <div class=\"quick-actions\">\n            <el-button type=\"primary\" plain icon=\"el-icon-plus\" @click=\"$router.push('/doctor/image-analysis')\">\n              新建分析\n            </el-button>\n            <el-button type=\"primary\" plain icon=\"el-icon-user\" @click=\"$router.push('/doctor/patients')\">\n              患者管理\n            </el-button>\n            <el-button type=\"primary\" plain icon=\"el-icon-document\" @click=\"$router.push('/doctor/reports')\">\n              报告管理\n            </el-button>\n            <el-button type=\"primary\" plain icon=\"el-icon-user\" @click=\"$router.push('/doctor/profile')\">\n              个人信息\n            </el-button>\n          </div>\n          <div class=\"system-info\">\n            <div class=\"info-item\">\n              <span class=\"label\">系统版本</span>\n              <span class=\"value\">V1.0.0</span>\n            </div>\n            <div class=\"info-item\">\n              <span class=\"label\">更新日期</span>\n              <span class=\"value\">2024-01-01</span>\n            </div>\n            <div class=\"info-item\">\n              <span class=\"label\">技术支持</span>\n              <span class=\"value\">IMID技术团队</span>\n            </div>\n          </div>\n        </el-card>\n      </el-col>\n    </el-row>\n  </div>\n</template>\n\n<script>\nimport { getHomeStats, getDoctorProfile } from '@/api/doctor'\n\nexport default {\n  name: 'DoctorHome',\n  data() {\n    return {\n      doctorInfo: {},\n      stats: {\n        pendingImages: 0,\n        todayPatients: 0,\n        totalReports: 0\n      }\n    }\n  },\n  created() {\n    this.fetchData()\n  },\n  methods: {\n    async fetchData() {\n      try {\n        // 获取医生信息\n        const profileRes = await getDoctorProfile()\n        this.doctorInfo = profileRes.data\n\n        // 获取统计数据\n        const statsRes = await getHomeStats()\n        this.stats = statsRes.data\n      } catch (error) {\n        console.error('获取数据失败:', error)\n        this.$message.error('获取数据失败')\n      }\n    }\n  }\n}\n</script>\n\n<style lang=\"scss\" scoped>\n.doctor-home {\n  padding: 24px;\n  background-color: #f5f7fa;\n  min-height: calc(100vh - 60px);\n\n  .welcome-card {\n    margin-bottom: 24px;\n    border-radius: 8px;\n    box-shadow: 0 2px 12px 0 rgba(0,0,0,0.05);\n\n    .welcome-content {\n      display: flex;\n      align-items: center;\n      gap: 24px;\n      padding: 20px;\n\n      .welcome-text {\n        h2 {\n          margin: 0 0 12px 0;\n          font-size: 28px;\n          color: #303133;\n          font-weight: 600;\n        }\n\n        p {\n          margin: 0;\n          color: #606266;\n          font-size: 16px;\n        }\n      }\n    }\n  }\n\n  .stat-row {\n    margin-bottom: 24px;\n\n    .stat-card {\n      height: 160px;\n      border-radius: 8px;\n      position: relative;\n      padding: 24px;\n      transition: all 0.3s;\n\n      &:hover {\n        transform: translateY(-5px);\n        box-shadow: 0 4px 20px rgba(0,0,0,0.1);\n      }\n\n      .stat-icon {\n        font-size: 48px;\n        color: #409EFF;\n        margin-bottom: 16px;\n      }\n\n      .stat-info {\n        .stat-value {\n          font-size: 36px;\n          font-weight: 600;\n          color: #303133;\n          line-height: 1;\n          margin-bottom: 8px;\n        }\n\n        .stat-label {\n          color: #606266;\n          font-size: 16px;\n        }\n      }\n\n      .stat-action {\n        position: absolute;\n        bottom: 16px;\n        right: 16px;\n        font-size: 14px;\n        \n        i {\n          margin-left: 4px;\n        }\n      }\n    }\n  }\n\n  .info-row {\n    .info-card {\n      border-radius: 8px;\n      height: 100%;\n      transition: all 0.3s;\n\n      &:hover {\n        transform: translateY(-5px);\n        box-shadow: 0 4px 20px rgba(0,0,0,0.1);\n      }\n\n      .info-header {\n        font-size: 18px;\n        font-weight: 600;\n        color: #303133;\n      }\n\n      .info-content {\n        padding: 16px 0;\n\n        .info-title {\n          font-size: 20px;\n          font-weight: 600;\n          color: #303133;\n          margin-bottom: 16px;\n        }\n\n        .info-desc {\n          color: #606266;\n          line-height: 1.8;\n          margin-bottom: 24px;\n        }\n\n        .feature-list {\n          display: grid;\n          grid-template-columns: repeat(2, 1fr);\n          gap: 16px;\n\n          .feature-item {\n            display: flex;\n            align-items: center;\n            gap: 8px;\n            color: #409EFF;\n\n            i {\n              font-size: 16px;\n            }\n          }\n        }\n      }\n\n      .quick-actions {\n        display: grid;\n        grid-template-columns: repeat(2, 1fr);\n        gap: 16px;\n        margin-bottom: 24px;\n\n        .el-button {\n          width: 100%;\n          height: 40px;\n        }\n      }\n\n      .system-info {\n        border-top: 1px solid #ebeef5;\n        padding-top: 16px;\n\n        .info-item {\n          display: flex;\n          justify-content: space-between;\n          margin-bottom: 12px;\n          color: #606266;\n\n          .label {\n            color: #909399;\n          }\n\n          &:last-child {\n            margin-bottom: 0;\n          }\n        }\n      }\n    }\n  }\n}\n</style> "]}]}