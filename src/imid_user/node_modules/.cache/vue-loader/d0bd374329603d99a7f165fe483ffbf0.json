       <span>诊断信息</span>\n          </div>\n          \n          <el-descriptions :column=\"1\" border>\n            <el-descriptions-item label=\"患者姓名\">\n              {{ imageInfo.patientName }}\n            </el-descriptions-item>\n            <el-descriptions-item label=\"影像类型\">\n              {{ imageInfo.imageType }}\n            </el-descriptions-item>\n            <el-descriptions-item label=\"上传时间\">\n              {{ formatDateTime(imageInfo.createdAt) }}\n            </el-descriptions-item>\n            <el-descriptions-item label=\"AI诊断结果\">\n              {{ imageInfo.aiDiagnosis }}\n              <template v-if=\"imageInfo.confidenceScore\">\n                <el-progress \n                  :percentage=\"Math.round(imageInfo.confidenceScore * 100)\"\n                  :color=\"getConfidenceColor\"\n                />\n              </template>\n            </el-descriptions-item>\n            <el-descriptions-item label=\"医生诊断\">\n              {{ imageInfo.doctorDiagnosis || '暂无' }}\n            </el-descriptions-item>\n            <el-descriptions-item label=\"主治医生\">\n              {{ imageInfo.doctorName || '暂无' }}\n            </el-descriptions-item>\n            <el-descriptions-item label=\"治疗方案\">\n              {{ imageInfo.treatmentPlan || '暂无' }}\n            </el-descriptions-item>\n            <el-descriptions-item label=\"医生建议\">\n              {{ imageInfo.recommendations || '暂无' }}\n            </el-descriptions-item>\n          </el-descriptions>\n        </el-card>\n      </el-col>\n    </el-row>\n  </div>\n</template>\n\n<script>\nimport { formatDateTime } from '@/utils/format'\nimport { getImageUrl, handleImageError } from '@/utils/image'\n\nexport default {\n  name: 'ImageViewer',\n  \n  props: {\n    imageInfo: {\n      type: Object,\n      required: true\n    }\n  },\n\n  methods: {\n    formatDateTime,\n    getImageUrl,\n    handleImageError,\n\n    getConfidenceColor(percentage) {\n      if (percentage > 80) return '#67C23A'\n      if (percentage > 60) return '#E6A23C'\n      return '#F56C6C'\n    }\n  }\n}\n</script>\n\n<style lang=\"scss\" scoped>\n.image-viewer {\n  padding: 20px;\n\n  .image-container {\n    width: 100%;\n    height: 400px;\n    display: flex;\n    justify-content: center;\n    align-items: center;\n    background: #f5f7fa;\n\n    .el-image {\n      max-width: 100%;\n      max-height: 100%;\n    }\n  }\n\n  .image-slot {\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    justify-content: center;\n    height: 100%;\n    color: #909399;\n\n    i {\n      font-size: 28px;\n      margin-bottom: 10px;\n    }\n  }\n\n  ::v-deep .el-descriptions-item__label {\n    width: 120px;\n    background-color: #fafafa;\n  }\n\n  ::v-deep .el-descriptions-item__content {\n    padding: 12px 15px;\n  }\n\n  .el-progress {\n    margin: 8px 0;\n  }\n}\n</style> "]}]}