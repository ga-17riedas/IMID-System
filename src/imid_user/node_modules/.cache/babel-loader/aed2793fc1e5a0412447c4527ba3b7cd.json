{"remainingRequest":"D:\\IMID\\src\\imid_user\\node_modules\\babel-loader\\lib\\index.js!D:\\IMID\\src\\imid_user\\node_modules\\eslint-loader\\index.js??ref--14-0!D:\\IMID\\src\\imid_user\\utils\\request.js","dependencies":[{"path":"D:\\IMID\\src\\imid_user\\utils\\request.js","mtime":1745200580408},{"path":"D:\\IMID\\src\\imid_user\\babel.config.js","mtime":1737217986000},{"path":"D:\\IMID\\src\\imid_user\\node_modules\\cache-loader\\dist\\cjs.js","mtime":1742797319000},{"path":"D:\\IMID\\src\\imid_user\\node_modules\\babel-loader\\lib\\index.js","mtime":1742797321000},{"path":"D:\\IMID\\src\\imid_user\\node_modules\\eslint-loader\\index.js","mtime":1742797320000}],"contextDependencies":[],"result":[{"type":"Buffer","data":"base64:"},{"version":3,"names":["axios","getToken","removeToken","removeUser","setToken","message","router","request","create","baseURL","process","env","VUE_APP_BASE_API","timeout","withCredentials","headers","interceptors","use","config","token","console","log","url","error","Promise","reject","response","newToken","status","data","push"],"sources":["D:/IMID/src/imid_user/utils/request.js"],"sourcesContent":["/**\n * HTTP请求封装模块\n * 基于axios的请求库，统一处理HTTP请求和响应\n */\nimport axios from 'axios'\nimport { getToken, removeToken, removeUser, setToken } from '@/utils/auth'\nimport { message } from 'ant-design-vue'\nimport router from '@/router'\n\n/**\n * 创建axios实例\n * 配置基础URL、超时时间、跨域凭证和默认请求头\n */\nconst request = axios.create({\n  baseURL: process.env.VUE_APP_BASE_API || 'http://localhost:8080',\n  timeout: 60000,  // 60秒超时时间\n  withCredentials: true,  // 允许跨域请求携带凭证\n  headers: {\n    'Content-Type': 'application/json',\n    'Accept': 'application/json'\n  }\n})\n\n/**\n * 请求拦截器\n * 在发送请求前自动添加认证令牌\n */\nrequest.interceptors.request.use(\n  config => {\n    const token = getToken()\n    console.log('Request URL:', config.url)\n    console.log('Current token:', token)\n    \n    if (token) {\n      // 确保Bearer token格式正确\n      config.headers['Authorization'] = `Bearer ${token}`\n      console.log('Setting Authorization header:', config.headers['Authorization'])\n    } else {\n      console.log('No token found')\n    }\n    \n    return config\n  },\n  error => {\n    console.error('Request interceptor error:', error)\n    return Promise.reject(error)\n  }\n)\n\n/**\n * 响应拦截器\n * 处理响应数据和统一处理错误码\n * 可以处理令牌刷新和会话过期等场景\n */\nrequest.interceptors.response.use(\n  response => {\n    // 处理令牌刷新\n    const newToken = response.headers['new-token']\n    if (newToken) {\n      setToken(newToken)\n    }\n    return response\n  },\n  error => {\n    // 统一处理HTTP错误状态码\n    if (error.response) {\n      switch (error.response.status) {\n        case 400:\n          message.error(error.response.data.message || '请求参数错误')\n          break\n        case 401:\n          // 未授权，清除用户信息并跳转到登录页\n          message.error('未授权，请重新登录')\n          removeToken()\n          removeUser()\n          router.push('/login')\n          break\n        case 403:\n          message.error('拒绝访问')\n          break\n        case 404:\n          message.error('请求错误，未找到该资源')\n          break\n        case 500:\n          message.error('服务器端出错')\n          break\n        default:\n          message.error(error.response.data.message || '操作失败，请重试')\n      }\n    } else {\n      // 网络错误或请求被取消\n      message.error('网络错误，请检查网络连接')\n    }\n    return Promise.reject(error)\n  }\n)\n\nexport default request "],"mappings":";AAAA;AACA;AACA;AACA;AACA,OAAOA,KAAK,MAAM,OAAO;AACzB,SAASC,QAAQ,EAAEC,WAAW,EAAEC,UAAU,EAAEC,QAAQ,QAAQ,cAAc;AAC1E,SAASC,OAAO,QAAQ,gBAAgB;AACxC,OAAOC,MAAM,MAAM,UAAU;;AAE7B;AACA;AACA;AACA;AACA,MAAMC,OAAO,GAAGP,KAAK,CAACQ,MAAM,CAAC;EAC3BC,OAAO,EAAEC,OAAO,CAACC,GAAG,CAACC,gBAAgB,IAAI,uBAAuB;EAChEC,OAAO,EAAE,KAAK;EAAG;EACjBC,eAAe,EAAE,IAAI;EAAG;EACxBC,OAAO,EAAE;IACP,cAAc,EAAE,kBAAkB;IAClC,QAAQ,EAAE;EACZ;AACF,CAAC,CAAC;;AAEF;AACA;AACA;AACA;AACAR,OAAO,CAACS,YAAY,CAACT,OAAO,CAACU,GAAG,CAC9BC,MAAM,IAAI;EACR,MAAMC,KAAK,GAAGlB,QAAQ,CAAC,CAAC;EACxBmB,OAAO,CAACC,GAAG