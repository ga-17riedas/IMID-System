    </div>\r\n      </el-header>\r\n      \r\n      <el-main>\r\n        <h1>用户使用手册</h1>\r\n        \r\n        <el-tabs v-model=\"activeTab\">\r\n          <!-- 医生端使用手册 -->\r\n          <el-tab-pane label=\"医生端使用手册\" name=\"doctor\">\r\n            <div class=\"guide-section\">\r\n              <h2>1. 登录系统</h2>\r\n              <p>使用医生账号登录系统，进入医生工作台。</p>\r\n              \r\n              <h2>2. 查看待处理影像</h2>\r\n              <p>在工作台首页可以查看待处理的医学影像列表，包括：</p>\r\n              <ul>\r\n                <li>待分析影像</li>\r\n                <li>待审核报告</li>\r\n                <li>待确认诊断</li>\r\n              </ul>\r\n              \r\n              <h2>3. 影像分析</h2>\r\n              <p>点击待处理影像，进入影像分析页面：</p>\r\n              <ul>\r\n                <li>查看原始影像</li>\r\n                <li>查看AI分析结果</li>\r\n                <li>进行人工诊断</li>\r\n                <li>生成诊断报告</li>\r\n              </ul>\r\n              \r\n              <h2>4. 报告管理</h2>\r\n              <p>在报告管理页面可以：</p>\r\n              <ul>\r\n                <li>查看所有诊断报告</li>\r\n                <li>编辑报告内容</li>\r\n                <li>确认报告</li>\r\n                <li>导出报告</li>\r\n              </ul>\r\n              \r\n              <h2>5. 患者管理</h2>\r\n              <p>在患者管理页面可以：</p>\r\n              <ul>\r\n                <li>查看患者列表</li>\r\n                <li>查看患者病历</li>\r\n                <li>查看患者影像历史</li>\r\n                <li>与患者沟通</li>\r\n              </ul>\r\n              \r\n              <h2>6. 排班管理</h2>\r\n              <p>在排班管理页面可以：</p>\r\n              <ul>\r\n                <li>设置出诊时间</li>\r\n                <li>查看预约情况</li>\r\n                <li>管理预约信息</li>\r\n              </ul>\r\n            </div>\r\n          </el-tab-pane>\r\n          \r\n          <!-- 患者端使用手册 -->\r\n          <el-tab-pane label=\"患者端使用手册\" name=\"patient\">\r\n            <div class=\"guide-section\">\r\n              <h2>1. 登录系统</h2>\r\n              <p>使用患者账号登录系统，进入患者个人中心。</p>\r\n              \r\n              <h2>2. 查看健康档案</h2>\r\n              <p>在个人中心可以查看：</p>\r\n              <ul>\r\n                <li>基本信息</li>\r\n                <li>健康记录</li>\r\n                <li>检查报告</li>\r\n                <li>用药记录</li>\r\n              </ul>\r\n              \r\n              <h2>3. 查看诊断报告</h2>\r\n              <p>在诊断报告页面可以：</p>\r\n              <ul>\r\n                <li>查看所有检查报告</li>\r\n                <li>查看报告详情</li>\r\n                <li>下载报告PDF</li>\r\n                <li>分享报告给其他医生</li>\r\n              </ul>\r\n              \r\n              <h2>4. 预约管理</h2>\r\n              <p>在预约管理页面可以：</p>\r\n              <ul>\r\n                <li>查看可预约医生</li>\r\n                <li>选择预约时间</li>\r\n                <li>查看预约记录</li>\r\n                <li>取消预约</li>\r\n              </ul>\r\n              \r\n              <h2>5. 健康记录</h2>\r\n              <p>在健康记录页面可以：</p>\r\n              <ul>\r\n                <li>记录日常健康数据</li>\r\n                <li>查看健康趋势</li>\r\n                <li>设置健康提醒</li>\r\n                <li>导出健康报告</li>\r\n              </ul>\r\n              \r\n              <h2>6. 在线咨询</h2>\r\n              <p>在咨询页面可以：</p>\r\n              <ul>\r\n                <li>选择咨询医生</li>\r\n                <li>发送文字消息</li>\r\n                <li>上传图片资料</li>\r\n                <li>查看咨询历史</li>\r\n              </ul>\r\n            </div>\r\n          </el-tab-pane>\r\n        </el-tabs>\r\n      </el-main>\r\n    </el-container>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nexport default {\r\n  name: 'UserGuide',\r\n  data() {\r\n    return {\r\n      activeTab: 'doctor'\r\n    }\r\n  }\r\n}\r\n</script>\r\n\r\n<style scoped>\r\n.user-guide {\r\n  min-height: 100vh;\r\n  background-color: #f5f7fa;\r\n}\r\n\r\n.header-content {\r\n  display: flex;\r\n  justify-content: space-between;\r\n  align-items: center;\r\n  height: 100%;\r\n  padding: 0 20px;\r\n}\r\n\r\n.logo {\r\n  display: flex;\r\n  align-items: center;\r\n}\r\n\r\n.logo img {\r\n  height: 40px;\r\n  margin-right: 10px;\r\n}\r\n\r\