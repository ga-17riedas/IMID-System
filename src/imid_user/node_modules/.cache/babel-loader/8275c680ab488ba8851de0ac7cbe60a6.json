","types","created"],"sources":["views/doctor/ReportManagement.vue"],"sourcesContent":["<template>\n  <div class=\"report-management\">\n    <el-card>\n      <div slot=\"header\" class=\"header\">\n        <span>报告管理</span>\n        <el-radio-group v-model=\"reportType\" size=\"small\">\n          <el-radio-button label=\"all\">全部报告</el-radio-button>\n          <el-radio-button label=\"analyzed\">已分析</el-radio-button>\n          <el-radio-button label=\"unanalyzed\">待分析</el-radio-button>\n        </el-radio-group>\n      </div>\n\n      <el-table\n        v-loading=\"loading\"\n        :data=\"filteredReports\"\n        border\n        style=\"width: 100%\">\n        <el-table-column\n          prop=\"id\"\n          label=\"报告ID\"\n          width=\"80\">\n        </el-table-column>\n        \n        <el-table-column\n          prop=\"patient.fullName\"\n          label=\"患者姓名\"\n          width=\"120\">\n          <template slot-scope=\"scope\">\n            {{ scope.row.patient?.fullName || '-' }}\n          </template>\n        </el-table-column>\n\n        <el-table-column\n          label=\"检查类型\"\n          width=\"120\">\n          <template slot-scope=\"scope\">\n            {{ scope.row.medicalImage?.imageType || '-' }}\n          </template>\n        </el-table-column>\n\n        <el-table-column\n          label=\"诊断结果\"\n          show-overflow-tooltip>\n          <template slot-scope=\"scope\">\n            {{ scope.row.diagnosis || '-' }}\n          </template>\n        </el-table-column>\n\n        <el-table-column\n          label=\"创建时间\"\n          width=\"180\">\n          <template slot-scope=\"scope\">\n            {{ formatDate(scope.row.createdAt) }}\n          </template>\n        </el-table-column>\n\n        <el-table-column\n          label=\"操作\"\n          width=\"200\">\n          <template slot-scope=\"scope\">\n            <el-button\n              size=\"mini\"\n              @click=\"viewReport(scope.row)\">查看</el-button>\n            <el-button\n              size=\"mini\"\n              type=\"primary\"\n              @click=\"editReport(scope.row)\"\n              v-if=\"!scope.row.diagnosis\">分析</el-button>\n            <el-button\n              size=\"mini\"\n              type=\"success\"\n              @click=\"exportReport(scope.row)\"\n              v-if=\"scope.row.diagnosis\">导出</el-button>\n          </template>\n        </el-table-column>\n      </el-table>\n\n      <div class=\"pagination-container\">\n        <el-pagination\n          @size-change=\"handleSizeChange\"\n          @current-change=\"handleCurrentChange\"\n          :current-page=\"currentPage\"\n          :page-sizes=\"[10, 20, 50]\"\n          :page-size=\"pageSize\"\n          layout=\"total, sizes, prev, pager, next, jumper\"\n          :total=\"total\">\n        </el-pagination>\n      </div>\n    </el-card>\n\n    <!-- 报告详情对话框 -->\n    <el-dialog\n      title=\"报告详情\"\n      :visible.sync=\"dialogVisible\"\n      width=\"70%\">\n      <div v-if=\"currentReport\" class=\"report-detail\">\n        <h3>基本信息</h3>\n        <el-descriptions :column=\"2\" border>\n          <el-descriptions-item label=\"患者姓名\">{{ currentReport.patient?.fullName || '-' }}</el-descriptions-item>\n          <el-descriptions-item label=\"性别\">{{ currentReport.patient?.gender || '-' }}</el-descriptions-item>\n          <el-descriptions-item label=\"年龄\">{{ currentReport.patient?.age || '-' }}</el-descriptions-item>\n          <el-descriptions-item label=\"检查类型\">\n            {{ getImageType(currentReport.medicalImage?.imageType) || '-' }}\n          </el-descriptions-item>\n        </el-descriptions>\n        \n        <h3>医学影像</h3>\n        <div class=\"image-container\" v-if=\"currentReport.medicalImage?.imageUrl\">\n          <img \n            :src=\"getFullImageUrl(currentReport.medicalImage.imageUrl)\" \n            @error=\"handleImageError\"\n            alt=\"医学影像\"\n          >\n        </div>\n        <div v-else class=\"image-slot\">\n          暂无医学影像\n        </div>\n        \n        <h3>AI 分析结果</h3>\n        <el-descriptions :column=\"2\" border>\n          <el-descriptions-item label=\"AI诊断\">\n            {{ currentReport.medicalImage?.aiDiagnosis || '-' }}\n          </el-descriptions-item>\n          <el-descriptions-item label=\"置信度\">\n            {{ currentReport.medicalImage?.confidenceScore ? \n              (currentReport.medicalImage.confidenceScore * 100).toFixed(2) + '%' : '-' }}\n          </el-descriptions-item>\n        </el-descriptions>\n\n        <h3>医生诊断</h3>\n        <el-descriptions :column=\"1\" border>\n          <el-descriptions-item label=\"诊断结果\">{{ currentReport.diagnosis || '-' }}</el-descriptions-item>\n          <el-descriptions-item label=\"治疗方案\">{{ currentReport.treatmentPlan || '-' }}</el-descriptions-item>\n          <el-descriptions-item label=\"医生建议\">{{ currentReport.recommendations || '-' }}</el-descriptions-item>\n        </el-descriptions>\n      </div>\n    </el-dialog>\n  </div>\n</template>\n\n<script>\nimport { formatDate } from '@/utils/date'\nimport { getImageUrl, handleImageError } from '@/utils/image'\n\nexport default {\n  name: 'ReportManagement',\n  data() {\n    return {\n      loading: false,\n      reports: [],\n      currentPage: 1,\n      pageSize: 10,\n      total: 0,\n      reportType: 'all',\n      dialogVisible: false,\n      currentReport: null,\n      baseUrl: process.env.VUE_APP_BASE_API || ''\n    }\n  },\n  computed: {\n    filteredReports() {\n      if (this.reportType === 'all') return this.reports\n      \n      return this.reports.filter(report => {\n        if (this.reportType === 'analyzed') {\n          return report.diagnosis && report.medicalImage?.aiDiagnosis\n        } else {\n          return !report.diagnosis || !report.medicalImage?.aiDiagnosis\n        }\n      })\n    }\n  },\n  methods: {\n    formatDate,\n    async fetchReports() {\n      this.loading = true\n      try {\n        const response = await this.$http.get('/api/medical/diagnosis-reports', {\n          params: {\n            page: this.currentPage - 1,\n            size: this.pageSize\n          }\n        })\n        this.reports = response.data.content\n        this.total = response.data.totalElements\n      } catch (error) {\n        console.error('获取报告列表失败:', error)\n        this.$message.error('获取报告列表失败')\n      } finally {\n        this.loading = false\n      }\n    },\n    handleSizeChange(val) {\n      this.pageSize = val\n      this.fetchReports()\n    },\n    handleCurrentChange(val) {\n      this.currentPage = val\n      this.fetchReports()\n    },\n    async viewReport(report) {\n      try {\n        const response = await this.$http.get(`/api/medical/diagnosis-reports/${report.id}`)\n        this.currentReport = response.data\n        this.dialogVisible = true\n      } catch (error) {\n        console.error('获取报告详情失败:', error)\n        this.$message.error('获取报告详情失败')\n      }\n    },\n    editReport(report) {\n      this.$router.push(`/doctor/image-analysis?reportId=${report.id}`)\n    },\n    async exportReport(report) {\n      try {\n        const loading = this.$loading({\n          lock: true,\n          text: '正在生成报告...',\n          spinner: 'el-icon-loading',\n          background: 'rgba(0, 0, 0, 0.7)'\n        })\n\n        const response = await this.$http.post(`/api/medical/diagnosis-reports/${report.id}/export`, null, {\n          responseType: 'blob'\n        })\n        \n        const contentType = response.headers['content-type']\n        if (contentType && contentType.includes('application/json')) {\n          const reader = new FileReader()\n          reader.onload = () => {\n            const error = JSON.parse(reader.result)\n            this.$message.error(error.message || '导出失败')\n          }\n          reader.readAsText(response.data)\n          loading.close()\n          return\n        }\n        \n        const url = window.URL.createObjectURL(new Blob([response.data]))\n        const link = document.createElement('a')\n        link.href = url\n        link.setAttribute('download', `medical_report_${report.id}.pdf`)\n        document.body.appendChild(link)\n        link.click()\n        document.body.removeChild(link)\n        window.URL.revokeObjectURL(url)\n        \n        loading.close()\n        this.$message.success('报告导出成功')\n      } catch (error) {\n        console.error('导出失败:', error)\n        this.$message.error('导出失败，请重试')\n      }\n    },\n    getFullImageUrl(url) {\n      return getImageUrl(url)\n    },\n    handleImageError(e) {\n      handleImageError(e)\n    },\n    getImageType(type) {\n      const types = {\n        'BRAIN_TUMOR': '脑肿瘤诊断',\n        'COVID': '新冠肺炎诊断',\n        'OTHER': '其他检查'\n      }\n      return types[type] || type\n    }\n  },\n  created() {\n    this.fetchReports()\n  }\n}\n</script>\n\n<style scoped>\n.report-management {\n  padding: 20px;\n}\n\n.header {\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n}\n\n.pagination-container {\n  margin-top: 20px;\n  text-align: right;\n}\n\n.report-detail {\n  padding: 20px;\n}\n\n.report-detail h3 {\n  margin: 20px 0 10px;\n  color: #303133;\n}\n\n.report-detail p {\n  margin: 10px 0;\n  line-height: 1.6;\n  color: #606266;\n}\n\n.image-container {\n  margin: 20px 0;\n  text-align: center;\n}\n\n.image-container img {\n  max-width: 100%;\n  max-height: 400px;\n  object-fit: contain;\n}\n\n.image-slot {\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n  justify-content: center;\n  height: 200px;\n  background: #f5f7fa;\n  color: #909399;\n}\n</style> "],"mappings":";;;;;;AA6IA,SAAAA,UAAA;AACA,SAAAC,WAAA,EAAAC,gBAAA;AAEA;EACAC,IAAA;EACAC,KAAA;IACA;MACAC,OAAA;MACAC,OAAA;MACAC,WAAA;MACAC,QAAA;MACAC,KAAA;MACAC,UAAA;MACAC,aAAA;MACAC,aAAA;MACAC,OAAA,EAAAC,OAAA,CAAAC,GAAA,CAAAC,gBAAA;IACA;EACA;EACAC,QAAA;IACAC,gBAAA;MACA,SAAAR,UAAA,wBAAAJ,OAAA;MAEA,YAAAA,OAAA,CAAAa,MAAA,CAAAC,MAAA;QACA,SAAAV,UAAA;UAA