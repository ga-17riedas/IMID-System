{"remainingRequest":"D:\\IMID\\src\\imid_user\\node_modules\\thread-loader\\dist\\cjs.js!D:\\IMID\\src\\imid_user\\node_modules\\babel-loader\\lib\\index.js!D:\\IMID\\src\\imid_user\\node_modules\\eslint-loader\\index.js??ref--14-0!D:\\IMID\\src\\imid_user\\utils\\image.js","dependencies":[{"path":"D:\\IMID\\src\\imid_user\\utils\\image.js","mtime":1745200795648},{"path":"D:\\IMID\\src\\imid_user\\babel.config.js","mtime":1737217986000},{"path":"D:\\IMID\\src\\imid_user\\node_modules\\cache-loader\\dist\\cjs.js","mtime":1742797319000},{"path":"D:\\IMID\\src\\imid_user\\node_modules\\thread-loader\\dist\\cjs.js","mtime":1742797319000},{"path":"D:\\IMID\\src\\imid_user\\node_modules\\babel-loader\\lib\\index.js","mtime":1742797321000},{"path":"D:\\IMID\\src\\imid_user\\node_modules\\eslint-loader\\index.js","mtime":1742797320000}],"contextDependencies":[],"result":[{"type":"Buffer","data":"base64:"},{"version":3,"names":["getImageUrl","url","console","warn","log","startsWith","baseUrl","process","env","VUE_APP_BASE_API","fullUrl","handleImageError","e","error","target","src","require"],"sources":["D:/IMID/src/imid_user/utils/image.js"],"sourcesContent":["/**\r\n * 图像处理工具模块\r\n * 提供图像URL处理和图像加载错误处理功能\r\n */\r\n\r\n/**\r\n * 获取完整的图像URL\r\n * 将相对路径转换为完整的URL，处理不同的URL格式\r\n * \r\n * @param {string} url - 原始图像URL，可以是相对路径或完整URL\r\n * @returns {string} 处理后的完整图像URL\r\n */\r\nexport function getImageUrl(url) {\r\n  if (!url) {\r\n    console.warn('Empty image URL provided');\r\n    return '';\r\n  }\r\n\r\n  console.log('Processing image URL:', url);\r\n  \r\n  // 如果是完整的URL，直接返回\r\n  if (url.startsWith('http://') || url.startsWith('https://')) {\r\n    console.log('Full URL detected, returning as is:', url);\r\n    return url;\r\n  }\r\n\r\n  // 获取基础API URL\r\n  const baseUrl = process.env.VUE_APP_BASE_API || 'http://localhost:8080';\r\n  console.log('Base API URL:', baseUrl);\r\n\r\n  // 处理相对路径\r\n  let fullUrl;\r\n  if (url.startsWith('/')) {\r\n    // 如果路径以/开头，直接拼接到baseUrl后面\r\n    fullUrl = baseUrl + url;\r\n  } else {\r\n    // 否则添加/再拼接\r\n    fullUrl = baseUrl + '/' + url;\r\n  }\r\n\r\n  console.log('Generated full image URL:', fullUrl);\r\n  return fullUrl;\r\n}\r\n\r\n/**\r\n * 处理图像加载错误\r\n * 当图像无法加载时显示一个备用图像\r\n * \r\n * @param {Event} e - 图像错误事件对象\r\n */\r\nexport function handleImageError(e) {\r\n  console.error('Image loading error:', e);\r\n  if (e.target && e.target.src) {\r\n    console.error('Failed image URL:', e.target.src);\r\n  }\r\n  // 替换为默认的错误图像\r\n  e.target.src = require('@/assets/image-error.png');\r\n} "],"mappings":"AAAA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA,OAAO,SAASA,WAAWA,CAACC,GAAG,EAAE;EAC/B,IAAI,CAACA,GAAG,EAAE;IACRC,OAAO,CAACC,IAAI,CAAC,0BAA0B,CAAC;IACxC,OAAO,EAAE;EACX;EAEAD,OAAO,CAACE,GAAG,CAAC,uBAAuB,EAAEH,GAAG,CAAC;;EAEzC;EACA,IAAIA,GAAG,CAACI,UAAU,CAAC,SAAS,CAAC,IAAIJ,GAAG,CAACI,UAAU,CAAC,UAAU,CAAC,EAAE;IAC3DH,OAAO,CAACE,GAAG,CAAC,qCAAqC,EAAEH,GAAG,CAAC;IACvD,OAAOA,GAAG;EACZ;;EAEA;EACA,MAAMK,OAAO,GAAGC,OAAO,CAACC,GAAG,CAACC,gBAAgB,IAAI,uBAAuB;EACvEP,OAAO,CAACE,GAAG,CAAC,eAAe,EAAEE,OAAO,CAAC;;EAErC;EACA,IAAII,OAAO;EACX,IAAIT,GAAG,CAACI,UAAU,CAAC,GAAG,CAAC,EAAE;IACvB;IACAK,OAAO,GAAGJ,OAAO,GAAGL,GAAG;EACzB,CAAC,MAAM;IACL;IACAS,OAAO,GAAGJ,OAAO,GAAG,GAAG,GAAGL,GAAG;EAC/B;EAEAC,OAAO,CAACE,GAAG,CAAC,2BAA2B,EAAEM,OAAO,CAAC;EACjD,OAAOA,OAAO;AAChB;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA,OAAO,SAASC,gBAAgBA,CAACC,CAAC,EAAE;EAClCV,OAAO,CAACW,KAAK,CAAC,sBAAsB,EAAED,CAAC,CAAC;EACxC,IAAIA,CAAC,CAACE,MAAM,IAAIF,CAAC,CAACE,MAAM,CAACC,GAAG,EAAE;IAC5Bb,OAAO,CAACW,KAAK,CAAC,mBAAmB,EAAED,CAAC,CAACE,MAAM,CAACC,GAAG,CAAC;EAClD;EACA;EACAH,CAAC,CAACE,MAAM,CAACC,GAAG,GAAGC,OAAO,CAAC,0BAA0B,CAAC;AACpD","ignoreList":[]}]}