\n          const { data } = response\r\n          \r\n          if (data.systemLogo) {\r\n            commit('SET_SYSTEM_LOGO', data.systemLogo)\r\n          }\r\n          \r\n          if (data.systemName) {\r\n            commit('SET_SYSTEM_NAME', data.systemName)\r\n          }\r\n          \r\n          if (data.theme) {\r\n            commit('SET_THEME', data.theme)\r\n            document.body.className = `theme-${data.theme}`\r\n          }\r\n          \r\n          resolve(data)\r\n        })\r\n        .catch(error => {\r\n          reject(error)\r\n        })\r\n    })\r\n  },\r\n  \r\n  // 更新设置\r\n  updateSetting({ commit }, { key, value, group }) {\r\n    commit('UPDATE_SETTING', { key, value })\r\n  },\r\n  \r\n  // 刷新系统Logo\r\n  refreshSystemLogo({ commit }) {\r\n    getSystemSettings()\r\n      .then(response => {\r\n        const { data } = response\r\n        if (data.systemLogo) {\r\n          commit('SET_SYSTEM_LOGO', data.systemLogo)\r\n        }\r\n      })\r\n  },\r\n  \r\n  // 刷新系统名称\r\n  refreshSystemName({ commit }) {\r\n    getSystemSettings()\r\n      .then(response => {\r\n        const { data } = response\r\n        if (data.systemName) {\r\n          commit('SET_SYSTEM_NAME', data.systemName)\r\n        }\r\n      })\r\n  }\r\n}\r\n\r\nexport default {\r\n  namespaced: true,\r\n  state,\r\n  mutations,\r\n  actions\r\n} "],"mappings":"AAAA,SAASA,iBAAiB,QAAQ,gBAAgB;AAElD,MAAMC,KAAK,GAAG;EACZC,UAAU,EAAE,WAAW;EACvBC,UAAU,EAAE,UAAU;EACtBC,KAAK,EAAE;AACT,CAAC;AAED,MAAMC,SAAS,GAAG;EAChBC,eAAe,EAAEA,CAACL,KAAK,EAAEM,IAAI,KAAK;IAChCN,KAAK,CAACC,UAAU,GAAGK,IAAI;EACzB,CAAC;EACDC,eAAe,EAAEA,CAACP,KAAK,EAAEQ,IAAI,KAAK;IAChCR,KAAK,CAACE,UAAU,GAAGM,IAAI;EACzB,CAAC;EACDC,SAAS,EAAEA,CAACT,KAAK,EAAEG,KAAK,KAAK;IAC3BH,KAAK,CAACG,KAAK,GAAGA,KAAK;EACrB,CAAC;EACDO,cAAc,EAAEA,CAACV,KAAK,EAAE;IAAEW,GAAG;IAAEC;EAAM,CAAC,KAAK;IACzC,IAAIZ,KAAK,CAACa,cAAc,CAACF,GAAG,CAAC,EAAE;MAC7BX,KAAK,CAACW,GAAG,CAAC,GAAGC,KAAK;IACpB;EACF;AACF,CAAC;AAED,MAAME,OAAO,GAAG;EACd