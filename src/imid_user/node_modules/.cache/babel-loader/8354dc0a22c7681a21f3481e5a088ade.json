{"remainingRequest":"D:\\IMID\\src\\imid_user\\node_modules\\thread-loader\\dist\\cjs.js!D:\\IMID\\src\\imid_user\\node_modules\\babel-loader\\lib\\index.js!D:\\IMID\\src\\imid_user\\node_modules\\eslint-loader\\index.js??ref--14-0!D:\\IMID\\src\\imid_user\\utils\\websocket.js","dependencies":[{"path":"D:\\IMID\\src\\imid_user\\utils\\websocket.js","mtime":1747195362633},{"path":"D:\\IMID\\src\\imid_user\\babel.config.js","mtime":1737217986000},{"path":"D:\\IMID\\src\\imid_user\\node_modules\\cache-loader\\dist\\cjs.js","mtime":1742797319000},{"path":"D:\\IMID\\src\\imid_user\\node_modules\\thread-loader\\dist\\cjs.js","mtime":1742797319000},{"path":"D:\\IMID\\src\\imid_user\\node_modules\\babel-loader\\lib\\index.js","mtime":1742797321000},{"path":"D:\\IMID\\src\\imid_user\\node_modules\\eslint-loader\\index.js","mtime":1742797320000}],"contextDependencies":[],"result":[{"type":"Buffer","data":"base64:"},{"version":3,"names":["SockJS","Stomp","getToken","store","WebSocketService","constructor","socket","stompClient","connected","subscriptions","reconnectAttempts","maxReconnectAttempts","reconnectTimeout","connect","console","log","over","debug","token","headers","Authorization","frame","subscribe","handleSettingChange","handleNotification","error","disconnect","reconnect","delay","Math","min","pow","clearTimeout","setTimeout","forEach","subscription","unsubscribe","close","destination","callback","warn","message","data","JSON","parse","body","push","send","stringify","type","dispatch","key","value","group","wsService"],"sources":["D:/IMID/src/imid_user/utils/websocket.js"],"sourcesContent":["import SockJS from 'sockjs-client'\nimport Stomp from 'webstomp-client'\nimport { getToken } from '@/utils/auth'\nimport store from '@/store'\n\nclass WebSocketService {\n  constructor() {\n    this.socket = null\n    this.stompClient = null\n    this.connected = false\n    this.subscriptions = []\n    this.reconnectAttempts = 0\n    this.maxReconnectAttempts = 5\n    this.reconnectTimeout = null\n  }\n\n  /**\n   * 连接WebSocket服务器\n   */\n  connect() {\n    if (this.connected || this.socket) {\n      console.log('WebSocket已连接或正在连接中')\n      return\n    }\n\n    console.log('正在连接WebSocket服务器...')\n    \n    // 创建SockJS实例\n    this.socket = new SockJS('/ws')\n    \n    // 创建STOMP客户端\n    this.stompClient = Stomp.over(this.socket)\n    \n    // 禁用STOMP调试输出\n    this.stompClient.debug = () => {}\n    \n    // 获取认证Token\n    const token = getToken()\n    \n    // 连接头信息\n    const headers = {\n      Authorization: token ? `Bearer ${token}` : ''\n    }\n    \n    // 连接WebSocket服务器\n    this.stompClient.connect(\n      headers,\n      frame => {\n        this.connected = true\n        this.reconnectAttempts = 0\n        console.log('WebSocket连接成功:', frame)\n        \n        // 订阅系统设置变更主题\n        this.subscribe('/topic/settings', this.handleSettingChange)\n        \n        // 订阅系统通知主题\n        this.subscribe('/topic/notifications', this.handleNotification)\n      },\n      error => {\n        console.error('WebSocket连接错误:', error)\n        this.disconnect()\n        \n        // 尝试重新连接\n        this.reconnect()\n      }\n    )\n  }\n  \n  /**\n   * 重新连接WebSocket\n   */\n  reconnect() {\n    if (this.reconnectAttempts >= this.maxReconnectAttempts) {\n      console.log('已达到最大重连次数，停止重连')\n      return\n    }\n    \n    this.reconnectAttempts++\n    const delay = Math.min(30000, 1000 * Math.pow(2, this.reconnectAttempts)) // 指数退避策略\n    \n    console.log(`将在${delay/1000}秒后尝试重新连接，尝试次数：${this.reconnectAttempts}`)\n    \n    if (this.reconnectTimeout) {\n      clearTimeout(this.reconnectTimeout)\n    }\n    \n    this.reconnectTimeout = setTimeout(() => {\n      console.log('正在尝试重新连接...')\n      this.connect()\n    }, delay)\n  }\n  \n  /**\n   * 断开WebSocket连接\n   */\n  disconnect() {\n    if (this.stompClient) {\n      // 取消所有订阅\n      this.subscriptions.forEach(subscription => {\n        if (subscription && typeof subscription.unsubscribe === 'function') {\n          subscription.unsubscribe()\n        }\n      })\n      this.subscriptions = []\n      \n      // 断开连接\n      if (this.stompClient.connected) {\n        this.stompClient.disconnect()\n      }\n      this.stompClient = null\n    }\n    \n    if (this.socket) {\n      this.socket.close()\n      this.socket = null\n    }\n    \n    this.connected = false\n  }\n  \n  /**\n   * 订阅主题\n   * @param {string} destination 目标主题\n   * @param {function} callback 回调函数\n   * @returns {object} 订阅对象\n   */\n  subscribe(destination, callback) {\n    if (!this.connected || !this.stompClient) {\n      console.warn('WebSocket未连接，无法订阅:', destination)\n      return null\n    }\n    \n    console.log('订阅主题:', destination)\n    const subscription = this.stompClient.subscribe(destination, message => {\n      try {\n        const data = JSON.parse(message.body)\n        callback(data)\n      } catch (error) {\n        console.error('解析消息出错:', error, message.body)\n      }\n    })\n    \n    this.subscriptions.push(subscription)\n    return subscription\n  }\n  \n  /**\n   * 发送消息到服务器\n   * @param {string} destination 目标地址\n   * @param {object} body 消息内容\n   */\n  send(destination, body) {\n    if (!this.connected || !this.stompClient) {\n      console.warn('WebSocket未连接，无法发送消息:', destination)\n      return\n    }\n    \n    this.stompClient.send(\n      destination,\n      JSON.stringify(body),\n      { \n        'content-type': 'application/json',\n        Authorization: getToken() ? `Bearer ${getToken()}` : ''\n      }\n    )\n  }\n  \n  /**\n   * 处理设置变更消息\n   * @param {object} data 消息数据\n   */\n  handleSettingChange(data) {\n    console.log('收到设置变更:', data)\n    \n    // 根据设置类型处理\n    if (data.type === 'SETTING_CHANGED') {\n      // 派发Vuex Action来更新设置\n      store.dispatch('settings/updateSetting', {\n        key: data.key,\n        value: data.value,\n        group: data.group\n      })\n      \n      // 如果是特定设置，执行特定操作\n      switch (data.key) {\n        case 'system.logo':\n          // 更新系统Logo\n          store.dispatch('settings/refreshSystemLogo')\n          break\n        case 'system.name':\n          // 更新系统名称\n          store.dispatch('settings/refreshSystemName')\n          break\n        default:\n          // 其他设置更新\n          break\n      }\n    }\n  }\n  \n  /**\n   * 处理系统通知消息\n   * @param {object} data 消息数据\n   */\n  handleNotification(data) {\n    console.log('收到系统通知:', data)\n    \n    if (data.type === 'SYSTEM_NOTIFICATION') {\n      // 显示系统通知\n      store.dispatch('notification/showNotification', {\n        message: data.message,\n        type: 'info'\n      })\n    }\n  }\n}\n\n// 创建单例实例\nconst wsService = new WebSocketService()\n\nexport default wsService "],"mappings":";;;AAAA,OAAOA,MAAM,MAAM,eAAe;AAClC,OAAOC,KAAK,MAAM,iBAAiB;AACnC,SAASC,QAAQ,QAAQ,cAAc;AACvC,OAAOC,KAAK,MAAM,SAAS;AAE3B,MAAMC,gBAAgB,CAAC;EACrBC,WAAWA,CAAA,EAAG;IACZ,IAAI,CAACC,MAAM,GAAG,IAAI;IAClB,IAAI,CAACC,WAAW,GAAG,IAAI;IACvB,IAAI,CAACC,SAAS,GAAG,KAAK;IACtB,IAAI,CAACC,aAAa,GAAG,EAAE;IACvB,IAAI,CAACC,iBAAiB,GAAG,CAAC;IAC1B,IAAI,CAACC,oBAAoB,GAAG,CAAC;IAC7B,IAAI,CAACC,gBAAgB,GAAG,IAAI;EAC9B;;EAEA;AACF;AACA;EACEC,OAAOA,CAAA,EAAG;IACR,IAAI,IAAI,CAACL,SAAS,IAAI,IAAI,CAACF,MAAM,EAAE;MACjCQ,OAAO,CAACC,GAAG,CAAC,oBAAoB,CAAC;MACjC;IACF;IAEAD,OAAO,CAACC,GAAG,CAAC,qBAAqB,CAAC;;IAElC;IACA,IAAI,CAACT,MAAM,GAAG,IAAIN,MAAM,CAAC,KAAK,CAAC;;IAE/B;IACA,IAAI,CAACO,WAAW,GAAGN,KAAK,CAACe,IAAI,CAAC,IAAI,CAACV,MAAM,CAAC;;IAE1C;IACA,IAAI,CAACC,WAAW,CAACU,KAAK,GAAG,MAAM,CAAC,CAAC;;IAEjC;IACA,MAAMC,KAAK,GAAGhB,QAAQ,CAAC,CAAC;;IAExB;IACA,MAAMiB,OAAO,GAAG;MACdC,aAAa,EAAEF,KAAK,GAAG,UAAUA,KAAK,EAAE,GAAG;IAC7C,CAAC;;IAED;IACA,IAAI,CAACX,WAAW,CAACM,OAAO,CACtBM,OAAO,EACPE,KAAK,IAAI;MACP,IAAI,CAACb,SAAS,GAAG,IAAI;MACrB,IAAI,CAACE,iBAAiB,GAAG,CAAC;MAC1BI,OAAO,CAACC,GAAG,CAAC,gBAAgB,EAAEM,KAAK,CAAC;;MAEpC;MACA,IAAI,CAACC,SAAS,CAAC,iBAAiB,EAAE,IAAI,CAACC,mBAAmB,CAAC;;MAE3D;MACA,IAAI,CAACD,SAAS,CAAC,sBAAsB,EAAE,IAAI,CAACE,kBAAkB,CAAC;IACjE,CAAC,EACDC,KAAK,IAAI;MACPX,OAAO,CAACW,KAAK,