// 应用主题相关的类\r\n  if (theme === ThemeType.DARK) {\r\n    document.body.classList.add('dark-theme');\r\n    document.body.classList.remove('light-theme');\r\n  } else {\r\n    document.body.classList.add('light-theme');\r\n    document.body.classList.remove('dark-theme');\r\n  }\r\n};\r\n\r\n// 初始化主题\r\nexport const initTheme = () => {\r\n  const savedTheme = getTheme();\r\n  applyTheme(savedTheme);\r\n  return savedTheme;\r\n}; "],"mappings":"AAAA;;AAEA;AACA,OAAO,MAAMA,SAAS,GAAG;EACvBC,KAAK,EAAE,OAAO;EACdC,IAAI,EAAE;AACR,CAAC;;AAED;AACA,OAAO,MAAMC,SAAS,GAAIC,KAAK,IAAK;EAClCC,YAAY,CAACC,OAAO,CAAC,OAAO,EAAEF,KAAK,CAAC;AACtC,CAAC;;AAED;AACA,OAAO,MAAMG,QAAQ,GAAGA,CAAA,KAAM;EAC5B,OAAOF,YAAY,CAACG,OAAO,CAAC,OAAO,CAAC,IAAIR,SAAS,CAACC,KAAK,CAAC,CAAC;AAC3D,CAAC;;AAED;AACA,OAAO,MAAMQ,WAAW,GAAGA,CAAA,KAAM;EAC/B,MAAMC,YAAY,GAAGH,QAAQ,CAAC,CAAC;EAC/B,MAAMI,QAAQ,GAAGD,YAAY,KAAKV,SAAS,CAACC,KAAK,GAAGD,SAAS,CAACE,IAAI,GAAGF,SAAS,CAACC,KAAK;EACpFE,SAAS,CAACQ,QAAQ,CAAC;EACnBC,UAAU,CAACD,QAAQ,CAAC;EACpB,OAAOA,QAAQ;AACjB,CAAC;;AAED;AACA,OAAO,MAAMC,UAAU,GAAIR,KAAK,IAAK;EACnCS,QAAQ,CAACC,eAAe,CAACC,YAAY,CAAC,YAAY,EAAEX,KAAK,CAAC;;EAE1D;EACA,IAAIA,KAAK,KAAKJ,SAAS,CAACE,IAAI,EAAE;IAC5BW,QAAQ,CAACG,IAAI,CAACC,SAAS,CAACC,GAAG,CAAC,YAAY,CAAC;IACzCL,QAAQ,CAACG,IAAI,CAACC,SAAS,CAACE,MAAM,CAAC,aAAa,CAAC;EAC/C,CAAC,MAAM;IACLN,QAAQ,CAACG,IAAI,CAACC,SAAS,CAACC,GAAG,CAAC,aAAa,CAAC;IAC1CL,QAAQ,CAACG,IAAI,CAACC,SAAS,CAACE,MAAM,CAAC,YAAY,CAAC;EAC9C;AACF,CAAC;;AAED;AACA,OAAO,MAAMC,SAAS,GAAGA,CAAA,KAAM;EAC7B,MAAMC,UAAU,GAAGd,QAAQ,CAAC,CAAC;EAC7BK,UAAU,CAACS,UAAU,CAAC;EACtB,OAAOA,UAAU;AACnB,CAAC","ignoreList":[]}]}