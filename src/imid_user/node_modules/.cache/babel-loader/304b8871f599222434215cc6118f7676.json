url: `/api/patient/reports/${id}`,\r\n    method: 'get'\r\n  }).catch(error => {\r\n    console.error('API Error:', error)\r\n    throw error\r\n  })\r\n}\r\n\r\n/**\r\n * 获取最近的诊断记录\r\n * \r\n * @param {Object} params - 查询参数\r\n * @param {number} [params.limit=3] - 获取记录数量限制\r\n * @returns {Promise} - 返回最近诊断记录的Promise\r\n */\r\nexport function getRecentDiagnosis(params) {\r\n  return request({\r\n    url: '/api/patient/reports/recent',\r\n    method: 'get',\r\n    params\r\n  })\r\n} "],"mappings":"AAAA;AACA;AACA;AACA;AACA,OAAOA,OAAO,MAAM,iBAAiB;;AAErC;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA,OAAO,SAASC,mBAAmBA,CAACC,MAAM,EAAE;EAC1C,OAAOF,OAAO,CAAC;IACbG,GAAG,EAAE,sBAAsB;IAC3BC,MAAM,EAAE,KAAK;IACbF,MAAM,EAAE;MACNG,IAAI,EAAEH,MAAM,CAACG,IAAI,GAAG,CAAC;MAAE;MACvBC,IAAI,EAAEJ,MAAM,CAACI,IAAI;MACjBC,IAAI,EAAE,gBAAgB,CAAC;IACzB;EACF,CAAC,CAAC;AACJ;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA,OAAO,SAASC,kBAAkBA,CAACC,EAAE,EAAE;EACrC,OAAOT,OAAO,CAAC;IACbG,GAAG,EAAE,wBAAwBM,EAAE,EAAE;IACjCL,MAAM,EAAE;EACV,CAAC,CAAC,CAACM,KAAK,CAACC,KAAK,IAAI;IAChBC,OAAO,CAACD,KAAK,CAAC,YAAY,EAAEA,KAAK,CAAC;IAClC,MAAMA,KAAK;EACb,CAAC,CAAC;AACJ;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA,OAAO,SAASE,kBAAkBA,CAACX,MAAM,EAAE;EACzC,OAAOF,OAAO,CAAC;IACbG,GAAG,EAAE,6BAA6B;IAClCC,MAAM,EAAE,KAAK;IACbF;EACF,CAAC,CAAC;AACJ","ignoreList":[]}]}