teHealthRecord(data) {\r\n  return request({\r\n    url: '/api/patient/health/records',\r\n    method: 'post',\r\n    data\r\n  })\r\n}\r\n\r\n/**\r\n * 更新已有的健康记录\r\n * \r\n * @param {string|number} id - 健康记录ID\r\n * @param {Object} data - 更新的健康记录数据\r\n * @returns {Promise} - 返回更新结果的Promise\r\n */\r\nexport function updateHealthRecord(id, data) {\r\n  return request({\r\n    url: `/api/patient/health/records/${id}`,\r\n    method: 'put',\r\n    data\r\n  })\r\n}\r\n\r\n/**\r\n * 删除健康记录\r\n * \r\n * @param {string|number} id - 要删除的健康记录ID\r\n * @returns {Promise} - 返回删除结果的Promise\r\n */\r\nexport function deleteHealthRecord(id) {\r\n  return request({\r\n    url: `/api/patient/health/records/${id}`,\r\n    method: 'delete'\r\n  })\r\n} "],"mappings":"AAAA;AACA;AACA;AACA;AACA,OAAOA,OAAO,MAAM,iBAAiB;;AAErC;AACA;AACA;AACA;AACA;AACA,OAAO,SAASC,gBAAgBA,CAAA,EAAG;EACjC,OAAOD,OAAO,CAAC;IACbE,GAAG,EAAE,6BAA6B;IAClCC,MAAM,EAAE;EACV,CAAC,CAAC;AACJ;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA,OAAO,SAASC,cAAcA,CAAA,EAAG;EAC/B,OAAOJ,OAAO,CAAC;IACbE,GAAG,EAAE,2BAA2B;IAChCC,MAAM,EAAE;EACV,CAAC,CAAC;AACJ;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA,OAAO,SAASE,kBAAkBA,CAACC,IAAI,EAAE;EACvC,OAAON,OAAO,CAAC;IACbE,GAAG,EAAE,6BAA6B;IAClCC,MAAM,EAAE,MAAM;IACdG;EACF,CAAC,CAAC;AACJ;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA,OAAO,SAASC,kBAAkBA,CAACC,EAAE,EAAEF,IAAI,EAAE;EAC3C,OAAON,OAAO,CAAC;IACbE,GAAG,EAAE,+BAA+BM,EAAE,EAAE;IACxCL,MAAM,EAAE,KAAK;IACbG;EACF,CAAC,CAAC;AACJ;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA,OAAO,SAASG,kBAAkBA,CAACD,EAAE,EAAE;EACrC,OAAOR,OAAO,CAAC;IACbE,GAAG,EAAE,+BAA+BM,EAAE,EAAE;IACxCL,MAAM,EAAE;EACV,CAAC,CAAC;AACJ","ignoreList":[]}]}