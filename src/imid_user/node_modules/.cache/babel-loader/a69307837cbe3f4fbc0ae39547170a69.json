{"remainingRequest":"D:\\IMID\\src\\imid_user\\node_modules\\babel-loader\\lib\\index.js!D:\\IMID\\src\\imid_user\\node_modules\\cache-loader\\dist\\cjs.js??ref--1-0!D:\\IMID\\src\\imid_user\\node_modules\\vue-loader\\lib\\index.js??vue-loader-options!D:\\IMID\\src\\imid_user\\views\\admin\\SystemLogs.vue?vue&type=script&lang=js","dependencies":[{"path":"D:\\IMID\\src\\imid_user\\views\\admin\\SystemLogs.vue","mtime":1745062448982},{"path":"D:\\IMID\\src\\imid_user\\babel.config.js","mtime":1737217986000},{"path":"D:\\IMID\\src\\imid_user\\node_modules\\cache-loader\\dist\\cjs.js","mtime":1742797319000},{"path":"D:\\IMID\\src\\imid_user\\node_modules\\babel-loader\\lib\\index.js","mtime":1742797321000},{"path":"D:\\IMID\\src\\imid_user\\node_modules\\cache-loader\\dist\\cjs.js","mtime":1742797319000},{"path":"D:\\IMID\\src\\imid_user\\node_modules\\vue-loader\\lib\\index.js","mtime":1742797321000}],"contextDependencies":[],"result":[{"type":"Buffer","data":"base64:"},{"version":3,"names":["formatDate","getSystemLogs","clearSystemLogs","name","data","logs","loading","page","pageSize","total","dateRange","logLevel","showClearDialog","pickerOptions","shortcuts","text","onClick","picker","end","Date","start","setTime","getTime","$emit","created","fetchLogs","methods","params","size","level","length","startDate","toISOString","endDate","response","content","map","log","timestamp","totalElements","Array","isArray","console","warn","error","$message","getLogLevelType","types","ERROR","WARNING","INFO","DEBUG","handleDateChange","handleLevelChange","handleSizeChange","handleCurrentChange","clearLogs","success"],"sources":["views/admin/SystemLogs.vue"],"sourcesContent":["<template>\n  <div class=\"system-logs-container\">\n    <el-card>\n      <div slot=\"header\" class=\"page-header\">\n        <span>系统日志管理</span>\n        <div class=\"header-actions\">\n          <el-date-picker\n            v-model=\"dateRange\"\n            type=\"daterange\"\n            range-separator=\"至\"\n            start-placeholder=\"开始日期\"\n            end-placeholder=\"结束日期\"\n            :picker-options=\"pickerOptions\"\n            @change=\"handleDateChange\"\n          />\n          <el-select v-model=\"logLevel\" placeholder=\"日志级别\" @change=\"handleLevelChange\">\n            <el-option label=\"全部\" value=\"\" />\n            <el-option label=\"错误\" value=\"ERROR\" />\n            <el-option label=\"警告\" value=\"WARNING\" />\n            <el-option label=\"信息\" value=\"INFO\" />\n            <el-option label=\"调试\" value=\"DEBUG\" />\n          </el-select>\n          <el-button type=\"primary\" @click=\"fetchLogs\">查询</el-button>\n          <el-button type=\"danger\" @click=\"showClearDialog = true\">清除日志</el-button>\n        </div>\n      </div>\n      \n      <el-table\n        :data=\"logs\"\n        style=\"width: 100%\"\n        v-loading=\"loading\"\n        border\n      >\n        <el-table-column prop=\"timestamp\" label=\"时间\" width=\"180\">\n          <template slot-scope=\"scope\">\n            {{ formatDate(scope.row.timestamp) }}\n          </template>\n        </el-table-column>\n        <el-table-column prop=\"level\" label=\"级别\" width=\"100\">\n          <template slot-scope=\"scope\">\n            <el-tag :type=\"getLogLevelType(scope.row.level)\">\n              {{ scope.row.level }}\n            </el-tag>\n          </template>\n        </el-table-column>\n        <el-table-column prop=\"source\" label=\"来源\" width=\"150\"></el-table-column>\n        <el-table-column prop=\"message\" label=\"内容\"></el-table-column>\n      </el-table>\n      \n      <div class=\"pagination-container\">\n        <el-pagination\n          @size-change=\"handleSizeChange\"\n          @current-change=\"handleCurrentChange\"\n          :current-page=\"page\"\n          :page-sizes=\"[10, 20, 50, 100]\"\n          :page-size=\"pageSize\"\n          layout=\"total, sizes, prev, pager, next, jumper\"\n          :total=\"total\"\n        >\n        </el-pagination>\n      </div>\n    </el-card>\n    \n    <!-- 清除日志确认对话框 -->\n    <el-dialog\n      title=\"清除日志\"\n      :visible.sync=\"showClearDialog\"\n      width=\"500px\"\n    >\n      <div>\n        <p>确定要清除以下范围的日志吗？</p>\n        <p v-if=\"dateRange && dateRange.length === 2\">\n          时间范围：{{ formatDate(dateRange[0]) }} 至 {{ formatDate(dateRange[1]) }}\n        </p>\n        <p v-else>\n          时间范围：全部\n        </p>\n        <p>\n          日志级别：{{ logLevel ? logLevel : '全部' }}\n        </p>\n        <div class=\"warning-text\">\n          <i class=\"el-icon-warning\"></i>\n          <span>此操作不可逆，请谨慎操作！</span>\n        </div>\n      </div>\n      <span slot=\"footer\" class=\"dialog-footer\">\n        <el-button @click=\"showClearDialog = false\">取消</el-button>\n        <el-button type=\"danger\" @click=\"clearLogs\">确定清除</el-button>\n      </span>\n    </el-dialog>\n  </div>\n</template>\n\n<script>\nimport { formatDate } from '@/utils/format'\nimport { getSystemLogs, clearSystemLogs } from '@/api/admin'\n\nexport default {\n  name: 'SystemLogs',\n  data() {\n    return {\n      logs: [],\n      loading: false,\n      page: 1,\n      pageSize: 20,\n      total: 0,\n      dateRange: null,\n      logLevel: '',\n      showClearDialog: false,\n      pickerOptions: {\n        shortcuts: [\n          {\n            text: '最近一天',\n            onClick(picker) {\n              const end = new Date()\n              const start = new Date()\n              start.setTime(start.getTime() - 3600 * 1000 * 24)\n              picker.$emit('pick', [start, end])\n            }\n          },\n          {\n            text: '最近一周',\n            onClick(picker) {\n              const end = new Date()\n              const start = new Date()\n              start.setTime(start.getTime() - 3600 * 1000 * 24 * 7)\n              picker.$emit('pick', [start, end])\n            }\n          },\n          {\n            text: '最近一个月',\n            onClick(picker) {\n              const end = new Date()\n              const start = new Date()\n              start.setTime(start.getTime() - 3600 * 1000 * 24 * 30)\n              picker.$emit('pick', [start, end])\n            }\n          }\n        ]\n      }\n    }\n  },\n  created() {\n    this.fetchLogs()\n  },\n  methods: {\n    formatDate,\n    async fetchLogs() {\n      this.loading = true\n      try {\n        const params = {\n          page: this.page - 1,\n          size: this.pageSize\n        }\n        \n        if (this.logLevel) {\n          params.level = this.logLevel\n        }\n        \n        if (this.dateRange && this.dateRange.length === 2) {\n          params.startDate = this.dateRange[0].toISOString()\n          params.endDate = this.dateRange[1].toISOString()\n        }\n        \n        const response = await getSystemLogs(params)\n        \n        if (response && response.data) {\n          if (response.data.data && response.data.data.content) {\n            this.logs = response.data.data.content.map(log => ({\n              ...log,\n              timestamp: new Date(log.timestamp)\n            }))\n            this.total = response.data.data.totalElements || response.data.data.content.length\n          } else if (response.data.content && Array.isArray(response.data.content)) {\n            this.logs = response.data.content.map(log => ({\n              ...log,\n              timestamp: new Date(log.timestamp)\n            }))\n            this.total = response.data.totalElements || response.data.content.length\n          } else if (Array.isArray(response.data)) {\n            this.logs = response.data.map(log => ({\n              ...log,\n              timestamp: new Date(log.timestamp)\n            }))\n            this.total = response.data.length\n          } else {\n            this.logs = []\n            this.total = 0\n            console.warn('系统日志数据格式不符合预期', response.data)\n          }\n        } else {\n          this.logs = []\n          this.total = 0\n        }\n      } catch (error) {\n        console.error('获取系统日志失败:', error)\n        this.$message.error('获取系统日志失败')\n        this.logs = []\n        this.total = 0\n      } finally {\n        this.loading = false\n      }\n    },\n    getLogLevelType(level) {\n      const types = {\n        ERROR: 'danger',\n        WARNING: 'warning',\n        INFO: 'info',\n        DEBUG: 'success'\n      }\n      return types[level] || 'info'\n    },\n    handleDateChange() {\n      // 日期变化时不自动查询，等用户点击查询按钮\n    },\n    handleLevelChange() {\n      // 级别变化时不自动查询，等用户点击查询按钮\n    },\n    handleSizeChange(size) {\n      this.pageSize = size\n      this.fetchLogs()\n    },\n    handleCurrentChange(page) {\n      this.page = page\n      this.fetchLogs()\n    },\n    async clearLogs() {\n      try {\n        let startDate = null\n        let endDate = null\n        \n        if (this.dateRange && this.dateRange.length === 2) {\n          startDate = this.dateRange[0].toISOString()\n          endDate = this.dateRange[1].toISOString()\n        }\n        \n        await clearSystemLogs(startDate, endDate)\n        this.$message.success('日志清除成功')\n        this.showClearDialog = false\n        this.fetchLogs() // 重新加载日志\n      } catch (error) {\n        console.error('清除日志失败:', error)\n        this.$message.error('清除日志失败')\n      }\n    }\n  }\n}\n</script>\n\n<style lang=\"scss\" scoped>\n.system-logs-container {\n  padding: 20px;\n  \n  .page-header {\n    display: flex;\n    justify-content: space-between;\n    align-items: center;\n    \n    .header-actions {\n      display: flex;\n      gap: 10px;\n    }\n  }\n  \n  .pagination-container {\n    margin-top: 20px;\n    text-align: right;\n  }\n  \n  .warning-text {\n    margin-top: 15px;\n    color: #E6A23C;\n    display: flex;\n    align-items: center;\n    \n    .el-icon-warning {\n      margin-right: 10px;\n      font-size: 18px;\n    }\n  }\n}\n</style> "],"mappings":";;AA8FA,SAAAA,UAAA;AACA,SAAAC,aAAA,EAAAC,eAAA;AAEA;EACAC,IAAA;EACAC,KAA