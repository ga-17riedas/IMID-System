 function getPatientHistory(patientId) {\n  return request({\n    url: `/api/doctors/patients/${patientId}/history`,\n    method: 'get'\n  })\n}\n\n// 获取患者诊断报告列表\nexport function getPatientReports(patientId) {\n  return request({\n    url: `/api/doctor/patients/${patientId}/reports`,\n    method: 'get'\n  })\n}\n\n// 导出诊断报告\nexport function exportReport(reportId) {\n  return request({\n    url: `/api/doctor/reports/${reportId}/export`,\n    method: 'get',\n    responseType: 'blob'\n  }).then(response => {\n    // 创建blob链接\n    const blob = new Blob([response.data], { type: 'application/pdf' })\n    const url = window.URL.createObjectURL(blob)\n    \n    // 创建一个临时链接并点击它来下载文件\n    const link = document.createElement('a')\n    link.href = url\n    link.download = 'report.pdf'\n    link.click()\n    \n    // 清理\n    window.URL.revokeObjectURL(url)\n  })\n}\n\n// 更新患者信息\nexport function updatePatient(patientId, data) {\n  return request({\n    url: `/api/doctors/patients/${patientId}`,\n    method: 'put',\n    data\n  })\n}\n\n// 添加更新病史记录的API\nexport function updateMedicalHistory(patientId, historyId, data) {\n  return request({\n    url: `/api/doctors/patients/${patientId}/history/${historyId}`,\n    method: 'put',\n    data\n  })\n}\n\n// 添加创建病史记录的API\nexport function createMedicalHistory(patientId, data) {\n  return request({\n    url: `/api/doctors/patients/${patientId}/history`,\n    method: 'post',\n    data\n  })\n}\n\n// 获取患者诊断记录\nexport function getPatientDiagnosis(patientId) {\n  return request({\n    url: `/api/doctors/patients/${patientId}/diagnosis`,\n    method: 'get'\n  })\n} "],"mappings":";;;AAAA,OAAOA,OAAO,MAAM,iBAAiB;AAErC,OAAO,SAASC,YAAYA,CAAA,EAAG;EAC7B,OAAOD,OAAO,CAAC;IACbE,GAAG,EAAE,wBAAwB;IAC7BC,MAAM,EAAE;EACV,CAAC,CAAC;AACJ;AAEA,OAAO,SAASC,WAAWA,CAAA,EAAG;EAC5B,OAAOJ,OAAO,CAAC;IACbE,GAAG,EAAE,sBAAsB;IAC3BC,MAAM,EAAE;EACV,CAAC,CAAC;AACJ;AAEA,OAAO,SAASE,YAAYA,CAACC,MAAM,EAAE;EACnC,OAAON,OAAO,CAAC;IACbE,GAAG,EAAE,uBAAuB;IAC5BC,MAAM,EAAE,KAAK;IACbG;E